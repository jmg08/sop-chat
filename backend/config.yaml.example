# SOP Chat 统一配置文件示例
# 复制此文件为 config.yaml 并填入实际配置

# ─── 全局配置 ─────────────────────────────────────────────────────────────────
global:
  # 支持直接填值或环境变量引用（$VAR / ${VAR}），变量不存在时保留原字面量
  accessKeyId: "$ACCESS_KEY_ID"
  accessKeySecret: "$ACCESS_KEY_SECRET"
  endpoint: "cms.cn-hangzhou.aliyuncs.com"
  port: 8080          # 监听端口，0 时读取 PORT 环境变量，默认 8080
  timeZone: "Asia/Shanghai"
  language: "zh"      # zh | en

# ─── 认证配置 ─────────────────────────────────────────────────────────────────
auth:
  # 鉴权链（有序列表）：builtin | ldap | oidc
  # 登录时按顺序尝试，第一个成功即返回 Token
  # 为空时登录功能关闭，所有受保护接口均不可访问（不推荐）
  methods: [builtin]
  # 链式示例（builtin 优先，找不到再走 LDAP）：
  # methods: [builtin, ldap]

  # JWT 令牌设置
  jwt:
    secretKey: your-secret-key-change-in-production  # 生产环境务必修改
    expiresIn: 24h    # 令牌有效期，如 24h、1h、30m

  # 内置用户密码加盐（可选）
  # 存储公式：MD5(passwordSalt + plaintext_password)，为空时退化为 MD5(plaintext_password)
  # passwordSalt: "your-site-secret"

  # 内置账号（builtin 方式专用）
  # 密码生成：echo -n "yourpassword" | md5sum
  # 配置了 passwordSalt 后需重新生成：echo -n "${passwordSalt}yourpassword" | md5sum
  builtinUsers:
    - name: admin
      password: 21232f297a57a5a743894a0e4a801fc3  # "admin" 的 MD5

  # 全局角色（所有认证方式共用；LDAP/OIDC 未来按映射规则写入此处）
  roles:
    - name: admin
      user:
        - admin

  # LDAP 认证（method: ldap 时启用）
  # ldap:
  #   host: ldap.example.com
  #   port: 389             # 明文 389，TLS 636
  #   useTLS: false
  #   bindDN: "cn=readonly,dc=example,dc=com"
  #   bindPassword: "$LDAP_BIND_PASSWORD"
  #   baseDN: "ou=people,dc=example,dc=com"
  #   userFilter: "(uid={username})"
  #   usernameAttr: uid     # 用于匹配用户名的属性
  #   displayAttr: cn       # 显示名属性
  #   emailAttr: mail

  # OIDC / OAuth2 认证（method: oidc 时启用）
  # 兼容 Keycloak、Dex、Okta、Azure AD 等标准 OIDC Provider
  # oidc:
  #   issuerURL: "https://accounts.example.com"
  #   clientId: "$OIDC_CLIENT_ID"
  #   clientSecret: "$OIDC_CLIENT_SECRET"
  #   redirectURL: "http://your-server:8080/api/auth/oidc/callback"
  #   scopes: [openid, profile, email]
  #   usernameClaim: preferred_username  # 从哪个 claim 提取用户名

# ─── 通知渠道配置（可选）────────────────────────────────────────────────────────
