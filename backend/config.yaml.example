#       allowedGroupUsers:        # 群用户白名单（钉钉 senderNick）：限制群聊中可 @ 机器人提问的用户；为空则允许所有群成员
#         - "张三"
#         - "李四"
#       allowedDirectUsers:       # 单聊用户白名单（钉钉 senderNick）：限制可与机器人单聊的用户；为空则允许所有人单聊
#         - "张三"
#       allowedConversations:     # 群白名单（conversationTitle）：为空则所有群均可；单聊不受此限制
#         - "研发一群"
#         - "SRE 值班群"
