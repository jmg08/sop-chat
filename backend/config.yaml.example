#       botLongConn:
#         enabled: true
#         botId: "$WECOM_BOT_ID"
#         botSecret: "$WECOM_BOT_SECRET"
#   wecomBot:                             # 企业微信群聊机器人（独立渠道，WebSocket 长连接）
